{
  "name": "github-actions-lsp",
  "description": "GitHub Actions workflow language server",
  "version": "1.0.0",
  "author": {
    "name": "andrewesweet"
  },
  "lspServers": {
    "github-actions": {
      "command": "actions-languageserver",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".yml": "yaml",
        ".yaml": "yaml"
      }
    }
  }
}
